<h1 class="text-center mt-2 mb-2"><%= @user.username%>'s Profile</h1>

<div class="container">
    <div class="row d-flex justify-content-center">
        <div class="col-6">
            <%= render 'shared/errors', obj:@user %>
            <%= form_with(model:@user,class:"shadow p-3 mb-3 bg-success rounded",local:true, data:{turbo: false}) do |form| %>
                <div class="form-group row mb-2">
                    <%= form.label :username, class:"col-2 col-form-label text-light"%>
                    <div class="col-10">
                        <input class="form-control" type="text" value= <%= @user.username %> aria-label="Disabled input example" disabled readonly>
                    </div>
                </div>
                <div class="form-group row mb-2">
                    <%= form.label :email, class:"col-2 col-form-label text-light"%>
                    <div class="col-10">
                        <input class="form-control" type="text" value= <%= @user.email %> aria-label="Disabled input example" disabled readonly>
                    </div>
                </div>
                <div class="form-group row mb-2">
                    <%= form.label :telephone, class:"col-2 col-form-label text-light"%>
                    <div class="col-10">
                        <input class="form-control" type="text" value= <%= @user.telephone %> aria-label="Disabled input example" disabled readonly>
                    </div>
                </div>
                <div class="form-group row mb-2">
                    <%= form.label :introduction, class:"col-2 col-form-label text-light"%>
                    <div class="col-10">
                        <input class="form-control" type="text" value= <%= @user.introduction %> aria-label="Disabled input example" disabled readonly>
                    </div>
                </div>
            <% end %>
        </div>
        <% if current_user != @user %>
            <div class="text-center">
                <% if !current_user.friends_with?(@user) %>
                    <% if current_user.receive_request_from?(@user) %>
                        <%= link_to "Accept friend request", friendship_path(sender_id: @user.id),data:{turbo_method: :patch},class:"btn btn-success" %>
                        <%= link_to "Reject friend request", friendships_path(sender_id: @user.id),data:{turbo_method: :delete}, class: "btn btn-warning" %>
                    <% elsif current_user.sent_request_to?(@user) %>
                        <%= link_to "Cancel friend request", friendship_path(receiver_id: @user.id),data:{turbo_method: :delete},class:"btn btn-secondary" %>
                    <% else %>
                        <%= link_to "Send friend request", friendships_path(receiver_id: @user.id), data:{turbo_method: :post}, class: "btn btn-info" %>
                    <% end %>
                <% else %>
                    <%= link_to "Unfriend", friendship_path(friend_id: @user.id), class:"btn btn-warning", data:{turbo_method: :delete, turbo_confirm:"Do you want to unfriend this user?"} %>
                <% end %>
            </div>
        <% else %>
            <div class="text-center">
                <% if current_user == @user %>
                    <%= link_to "Edit profile", edit_user_path(@user), class: "btn btn-warning" %>
                <% end %>
                <%= link_to "Return to Home Page", chatrooms_path, class: "btn btn-secondary" %>
                <% if current_user == @user %>
                    <%= link_to "Delete account", user_path(current_user), class: "btn btn-danger", data:{turbo_method: :delete, turbo_confirm: "Do you want to delete your account?"} %>
                <% end %>
            </div>
        <% end %>
    </div>
</div>