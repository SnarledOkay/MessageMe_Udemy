<nav id="page-navbar" class="navbar navbar-expand-lg bg-warning">
  <div class="container-fluid">
    <% if logged_in? %>
      <%= link_to "MessageMe", chatrooms_path, class:"navbar-brand", id:"logo" %>
    <% else %>
      <%= link_to "MessageMe", root_path, class:"navbar-brand", id:"logo" %>
    <% end %>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <%= link_to 'About Us', about_path, class:"nav-link" %>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Chatrooms
          </a>
          <div class="dropdown-menu">
            <%= link_to "Chatrooms", chatrooms_path, class:"dropdown-item" %>
            <%= link_to "Create group chat", new_chatroom_path, class:"dropdown-item" %>
          </div>
        </li>
        <li class="nav-item">
          <%= link_to 'Friends', friends_path, class: "nav-link" %>
        </li>
      </ul>
      <ul class="navbar-nav me-auto">
        <% if logged_in? %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              User <%= current_user.username %>
            </a>
            <div class="dropdown-menu">
              <%= link_to "View Profile", current_user, class:"dropdown-item" %>
              <%= link_to "Edit Profile", edit_user_path(current_user),class:"dropdown-item" %>
              <div class="dropdown-divider"></div>
              <%= link_to "Log out", logout_path ,class:"dropdown-item text-warning", data:{turbo_method: :delete, turbo_confirm:"Do you want to log out?"}%>
              <div class="dropdown-divider"></div>
              <%= link_to "Delete Account", user_path(current_user),class:"dropdown-item text-danger fw-bold", data:{turbo_method: :delete, turbo_confirm:"Do you want to delete account?"}%>
            </div>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Sign Up", sign_up_path, class:"nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Log in", login_path, class:"nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>